{
    "version": 6,
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "generator": "Unix Makefiles",
            "binaryDir": "build-debug-dev",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS_DEBUG": "-g -Wall",
                "CMAKE_C_FLAGS_DEBUG": "-g -Wall",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
                "GODZILLA_BUILD_EXAMPLES": "YES",
                "GODZILLA_BUILD_TESTS": "YES",
                "GODZILLA_CODE_COVERAGE": "YES",
                "GODZILLA_WITH_MPI": "YES"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "generator": "Unix Makefiles",
            "binaryDir": "build-release-dev",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS_RELEASE": "-O3",
                "CMAKE_C_FLAGS_RELEASE": "-O3",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "NO",
                "GODZILLA_BUILD_EXAMPLES": "NO",
                "GODZILLA_BUILD_TESTS": "NO",
                "GODZILLA_CODE_COVERAGE": "NO",
                "GODZILLA_WITH_MPI": "YES"
            }
        },
        {
            "name": "native",
            "displayName": "Native",
            "generator": "Unix Makefiles",
            "binaryDir": "build-native-dev",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS_RELEASE": "-O3 -march=native",
                "CMAKE_C_FLAGS_RELEASE": "-O3 -march=native",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "NO",
                "GODZILLA_BUILD_EXAMPLES": "NO",
                "GODZILLA_BUILD_TESTS": "NO",
                "GODZILLA_CODE_COVERAGE": "NO",
                "GODZILLA_WITH_MPI": "YES",
                "GODZILLA_WITH_TECIOCPP": "YES"
            }
        },
        {
            "name": "ci-debug",
            "displayName": "CI/Debug",
            "generator": "Unix Makefiles",
            "binaryDir": "build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS_DEBUG": "-g -O1 -Wall -Werror",
                "CMAKE_C_FLAGS_DEBUG": "-g -O1 -Wall -Werror",
                "GODZILLA_BUILD_EXAMPLES": "YES",
                "GODZILLA_BUILD_TESTS": "YES",
                "GODZILLA_WITH_MPI": "YES"
            }
        },
        {
            "name": "ci-release",
            "displayName": "CI/Release",
            "generator": "Unix Makefiles",
            "binaryDir": "build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS_RELEASE": "-O3 -Wall -Werror -DNDEBUG",
                "CMAKE_C_FLAGS_RELEASE": "-O3 -Wall -Werror -DNDEBUG",
                "GODZILLA_BUILD_EXAMPLES": "YES",
                "GODZILLA_BUILD_TESTS": "YES",
                "GODZILLA_WITH_MPI": "YES"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Debug Build",
            "configurePreset": "debug",
            "configuration": "Debug"
        },
        {
            "name": "release",
